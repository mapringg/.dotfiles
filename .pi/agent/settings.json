{
  "theme": "catppuccin-mocha",
  "defaultModel": "claude-opus-4-5-thinking",
  "defaultProvider": "google-antigravity",
  "defaultThinkingLevel": "high",
  "enabledModels": [
    "claude-opus-4-5-thinking",
    "claude-sonnet-4-5-thinking",
    "gemini-3-pro-preview",
    "gemini-3-flash-preview"
  ],
  "packages": [
    {
      "source": "https://github.com/mitsuhiko/agent-stuff",
      "themes": [
        "-pi-themes/nightowl.json"
      ],
      "prompts": [
        "-commands/update-changelog.md",
        "+commands/commit.md"
      ],
      "skills": [
        "-skills/update-changelog/SKILL.md",
        "-skills/sentry/SKILL.md",
        "-skills/pi-share/SKILL.md",
        "-skills/openscad/SKILL.md",
        "-skills/oebb-scotty/SKILL.md",
        "-skills/github/SKILL.md",
        "-skills/ghidra/SKILL.md",
        "-skills/anachb/SKILL.md",
        "+skills/tmux/SKILL.md",
        "+skills/commit/SKILL.md",
        "+skills/improve-skill/SKILL.md"
      ],
      "extensions": [
        "-pi-extensions/control.ts",
        "-pi-extensions/cwd-history.ts",
        "-pi-extensions/reveal.ts"
      ]
    }
  ],
  "lastChangelogVersion": "0.50.4"
}