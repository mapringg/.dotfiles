# Theme
# On Linux (Omarchy): uses the dynamic theme from Omarchy
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 14

# Window
window-padding-x = 14
window-padding-y = 14
window-padding-balance = true
confirm-close-surface = false
resize-overlay = never

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Shell integration + SSH session terminfo
shell-integration-features = no-cursor,ssh-env

# Cross-platform keybindings
keybind = shift+enter=text:\x1b\r

# Platform-specific configs (loaded conditionally)
config-file = ?"~/.config/ghostty/linux.conf"
config-file = ?"~/.config/ghostty/macos.conf"
