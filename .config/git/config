[include]
	path = ~/.config/git/catppuccin.gitconfig

[user]
	name = Sorawit Kongnurat
	email = sorawit.k@tutanota.com

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true

[commit]
	verbose = true

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = -version:refname

[rerere]
	enabled = true
	autoupdate = true

[delta]
	features = catppuccin-mocha
	navigate = true
	hunk-header-style = omit
	file-decoration-style = none
	file-modified-label = "modified:"
	line-numbers = true