[user]
  name = Sorawit Kongnurat
  email = sorawit.k@tutanota.com

[branch]
  sort = -committerdate

[column]
  ui = auto

[commit]
  verbose = true

[diff]
  algorithm = histogram
  colorMoved = default
  mnemonicPrefix = true

[fetch]
  prune = true

[merge]
  conflictstyle = diff3

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[rerere]
  enabled = true
  autoupdate = true

[tag]
  sort = -version:refname

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  dark = true
  paging = never
  hunk-header-decoration-style = plain
  hunk-header-style = file line-number syntax
  file-decoration-style = plain
  file-style = omit
