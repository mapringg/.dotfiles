{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "model": "vercel/anthropic/claude-opus-4.5",
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": true,
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
  },
}
