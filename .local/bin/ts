#!/usr/bin/env zsh

selected=$(
  fd --type d --hidden --no-ignore --glob '.git' --max-depth 3 \
    "$HOME/.dotfiles" "$HOME/Developer" 2>/dev/null |
    sed "s|/.git/||; s|^$HOME/Developer/||; s|^$HOME/||" |
    LC_ALL=C sort |
    fzf --cycle --layout=reverse
) || exit

if [[ -d "$HOME/Developer/$selected" ]]; then
  selected="$HOME/Developer/$selected"
else
  selected="$HOME/$selected"
fi

session_name="${selected#"$HOME/Developer/"}"
session_name="${session_name#"$HOME/"}"
session_name="${session_name//[.:]/_}"

if ! tmux has-session -t="$session_name" 2>/dev/null; then
  tmux new-session -ds "$session_name" -c "$selected"
fi

if [[ -z "$TMUX" ]]; then
  tmux attach-session -t "$session_name"
else
  tmux switch-client -t "$session_name"
fi
